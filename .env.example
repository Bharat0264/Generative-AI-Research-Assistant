# Backend
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CLIENT_URL=http://localhost:5173,https://your-vercel-app.vercel.app
MAX_FILE_SIZE_MB=15
MONGO_CONNECT_TIMEOUT_MS=10000

# AI provider. Use one provider key. If both are empty, the app uses local deterministic fallback embeddings
# and extractive fallback text generation for development.

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Frontend
VITE_API_URL=http://localhost:5000/api
# Production frontend value after Render deploy:
# VITE_API_URL=https://your-render-service.onrender.com/api
# Production frontend value for Vercel multi-service deploy:
# VITE_API_URL=/_/backend/api
